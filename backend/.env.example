# Copy this file to .env and fill in real values — never commit .env

# Port the server listens on (Railway sets this automatically)
PORT=5000

# MongoDB Atlas connection string
# Get from: Atlas dashboard → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# Gmail account used to send contact form emails
EMAIL_USER=your-gmail@gmail.com

# Gmail App Password (not your account password)
# Generate at: Google Account → Security → 2-Step Verification → App passwords
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Email address that receives contact form submissions
EMAIL_TO=your-email@example.com

# Frontend origin for CORS (no trailing slash)
# In development: http://localhost:5173
# In production: your Vercel domain, e.g. https://amanbansal.vercel.app
FRONTEND_URL=https://your-app.vercel.app

# Set to "production" on Railway
NODE_ENV=production
